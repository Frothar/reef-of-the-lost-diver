# Normalize line endings across Windows / macOS / Linux teammates.
* text=auto eol=lf

# Visual Studio files must stay CRLF
*.sln            text eol=crlf
*.vcxproj        text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user   text eol=crlf

# Source / shaders / docs -> LF
*.cpp  text eol=lf
*.hpp  text eol=lf
*.h    text eol=lf
*.c    text eol=lf
*.vert text eol=lf
*.frag text eol=lf
*.glsl text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Binary assets — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.dll binary
*.lib binary
*.obj binary
*.fbx binary
*.gltf binary
*.glb binary
*.ttf binary
