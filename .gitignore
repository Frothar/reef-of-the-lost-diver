# ===========================================================================
# .gitignore - Reef of the Lost Diver (group 13)
# ===========================================================================

# ---- Course lab framework (large, not our code, kept locally for dep restore) ----
/Grafika komputerowa - projekt z zajęć/

# ---- Class-wide tracking sheet (contains other students' names & links) ----
/GRK projekty 2026 - Sheet1.csv

# ---- Visual Studio / MSBuild build outputs ----
[Dd]ebug/
[Rr]elease/
x64/
Win32/
# MSVC object files — NIE ignoruj modeli 3D w models/
*.obj
!models/*.obj
*.pdb
*.ilk
*.idb
*.exp
*.lib.recipe
*.log
*.tlog
*.lastbuildstate
.vs/
*.VC.db
*.VC.opendb
*.aps

# ---- CMake build outputs ----
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
*.cmake
!CMakeLists.txt
# Compiled binary (CMake puts it in the project root next to the assets)
/UnderwaterScene

# ---- Heavy prebuilt Windows dependencies ----
# Restored locally from the GRK course framework's `dependencies/` folder
# (Windows) or installed via brew/apt (macOS/Linux). See BUILD.md.
/dependencies/assimp/
/dependencies/glew-2.0.0/
/dependencies/glfw-3.3.8.bin.WIN32/
/dependencies/glfw-3.3.8.bin.WIN64/
/dependencies/freeglut/
# Keep the header-only / source-only deps that BOTH build systems need:
!/dependencies/glm/
!/dependencies/imgui/

# ---- ImGui runtime state (per-machine window layout) ----
imgui.ini

# ---- OS cruft ----
.DS_Store
Thumbs.db
desktop.ini
